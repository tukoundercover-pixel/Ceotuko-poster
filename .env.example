# ---- Claude (caption generation) ----
ANTHROPIC_API_KEY=

# ---- Instagram Graph API ----
# Long-lived Page Access Token for the Facebook Page linked to your IG Business/Creator account
IG_ACCESS_TOKEN=
# The Instagram Business Account ID (NOT the Facebook Page ID)
IG_USER_ID=

# ---- TikTok Content Posting API ----
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# Obtained once via the OAuth flow (see README) — long-lived, refreshed automatically by the app
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=

# ---- Local app ----
# Folder you drop finished videos into (local mode)
WATCH_FOLDER=C:\Users\izzet\Videos\ceotuko_uploads
LOG_FILE=logs\post_log.csv

# ---- Cloud app (Railway) ----
# Dropbox folder is the cloud equivalent of WATCH_FOLDER
DROPBOX_ACCESS_TOKEN=
DROPBOX_WATCH_FOLDER=/ceotuko_uploads
# Password to protect the web dashboard
DASHBOARD_PASSWORD=
# Public base URL Railway gives your service, e.g. https://ceotuko-poster.up.railway.app
PUBLIC_BASE_URL=
